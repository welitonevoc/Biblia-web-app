{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth ID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile picture URL."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role in the application."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
